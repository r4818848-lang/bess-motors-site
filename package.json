{
  "name": "bess-motors",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev",
    "clean:cache": "node -e \"const fs=require('fs');for(const d of ['.next','test-results','playwright-report','tsconfig.tsbuildinfo']){try{fs.rmSync(d,{recursive:true,force:true})}catch(e){}}\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "audit": "node scripts/audit-site.mjs",
    "checkup": "npm run audit && npm run build",
    "checkup:full": "npm run audit && npm run build && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "purge:cloud": "node scripts/purge-cloud.mjs"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "bir1": "^4.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.15.0",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.3",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tesseract.js": "^7.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0"
  }
}
