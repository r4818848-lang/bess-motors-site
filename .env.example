# Site URL (sitemap, canonical, Open Graph — must match live domain in Vercel)
NEXT_PUBLIC_SITE_URL=https://www.bess-motors.com

# Google Search Console → Ownership verification → HTML tag (content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxx

# Google Analytics 4 (optional — enables GoogleAnalytics.tsx)
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel — https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=1670736437497545

# Meta Business Suite → Domains → HTML meta tag (content value only)
# NEXT_PUBLIC_FACEBOOK_DOMAIN_VERIFICATION=lt6qibm590hn899ajzy9ywie8qzgh9

# Vercel Cron — required for /api/telegram/cron/* (Authorization: Bearer CRON_SECRET)
# CRON_SECRET=random_long_string

# Telegram bot: clients book via /start; admin (TELEGRAM_CHAT_ID) sees CRM menu
# TELEGRAM_BOT_TOKEN= from @BotFather
# TELEGRAM_CHAT_ID= your admin chat id (737707795)
# TELEGRAM_ADMIN_CHAT_IDS= optional extra admin chat ids, comma-separated
# TELEGRAM_WEBHOOK_SECRET= random string for webhook validation
# TELEGRAM_SETUP_KEY= random key to call GET /api/telegram/setup?key=...
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=BessMotors_bot

# Web Push (npx web-push generate-vapid-keys)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:bessmotorss@gmail.com

# Supabase Storage for work-order photos (optional bucket, public read)
# SUPABASE_STORAGE_BUCKET=work-order-files

# Supabase — run supabase/appointments.sql and supabase/crm_store.sql in SQL Editor
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=secret from API Keys → Secret keys (sb_secret_...) or Legacy → service_role (eyJ...)

# --- Password reset SMS (choose one provider) ---
# SMS_PROVIDER=smsapi
# SMS_PROVIDER=twilio

# SMSAPI (Poland) — https://www.smsapi.com/
SMSAPI_TOKEN=your_smsapi_oauth_token
SMSAPI_FROM=BESS MOTORS

# Twilio — https://www.twilio.com/
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_NUMBER=+48123456789

# --- VIN decode (multi-source consensus; add keys in Vercel for best EU accuracy) ---
# Free without keys: NHTSA + WMI fallback
# Recommended for Poland/EU: TecDoc + VINdecoder.pl OR Vincario

# TecDoc VIN (same catalog family as Inter Cars / parts distributors)
# https://tecdoc-db.pro/ or your TecDoc API provider
# TECDOC_API_KEY=your_key
# TECDOC_API_BASE=http://webapi.auto-data.pro/tecdoc/vin
# TECDOC_LANG=pl

# VINdecoder.pl / AutoISO (Polish parts-market decoder)
# https://vindecoder.pl/en/api
# VINDECODER_PL_API_UID=your_uid
# VINDECODER_PL_API_KEY=your_key
# VINDECODER_PL_API_BASE=https://bp.autoiso.pl/api/v3
# VINDECODER_PL_LANG=pl

# Vincario — global EU decoder, free trial https://vincario.com/
# VINCARIO_API_KEY=your_key
# VINCARIO_API_SECRET=your_secret
# VINCARIO_API_BASE=https://api.vincario.com/3.2

# VINdata.io — European VIN API https://vindata.io/
# VINDATA_API_KEY=your_key
# VINDATA_API_BASE=https://gxvtafqbraaifsnthsyj.supabase.co/functions/v1/api-vin-decode

# Auto.dev — https://auto.dev/vin (1000 free calls/month)
# AUTO_DEV_API_KEY=your_key

# Note: Inter Cars API (webapi.intercars.eu) is for stock/orders, not VIN decode.
# Use TecDoc VIN API above for parts-catalog-grade vehicle identification.
