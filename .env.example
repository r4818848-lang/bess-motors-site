# Site URL (sitemap, canonical, Open Graph — must match live domain in Vercel)
NEXT_PUBLIC_SITE_URL=https://www.bess-motors.com

# Google Search Console → Ownership verification → HTML tag (content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxx

# --- Password reset SMS (choose one provider) ---
# SMS_PROVIDER=smsapi
# SMS_PROVIDER=twilio

# SMSAPI (Poland) — https://www.smsapi.com/
SMSAPI_TOKEN=your_smsapi_oauth_token
SMSAPI_FROM=BESS MOTORS

# Twilio — https://www.twilio.com/
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_NUMBER=+48123456789
